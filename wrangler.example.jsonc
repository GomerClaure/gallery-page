{
  "name": "academy-info-bafott",
  "compatibility_date": "2026-03-18",
  "pages_build_output_dir": "dist/proyecto-prueba/browser",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ACADEMY_INFO_BAFOTT_DB_NAME",
      "database_id": "REEMPLAZAR_CON_DATABASE_ID"
    }
  ],

  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "REEMPLAZAR_CON_BUCKET_NAME"
    }
  ]
}
